{
  "manifest_version": 3,
  "name": "Amazon Canada Shift Helper",
  "description": "Monitors Amazon Canada jobs pages and alerts you when shifts match selected cities.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://hiring.amazon.ca/*",
    "https://www.amazon.jobs/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Amazon Shift Helper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://hiring.amazon.ca/*",
        "https://www.amazon.jobs/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
